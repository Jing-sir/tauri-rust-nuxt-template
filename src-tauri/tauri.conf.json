{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Trading Desktop",
  "version": "0.1.0",
  "identifier": "com.xiangnan.tradingdesktop",
  "build": {
    "beforeDevCommand": "yarn dev --host 127.0.0.1 --port 1420",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "yarn generate",
    "frontendDist": "../.output/public"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Trading Desktop",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 700,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
